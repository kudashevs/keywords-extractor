includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
    tmpDir: build/phpstan
    checkMissingIterableValueType: true
    ignoreErrors:
        -
            message: "#^Method [a-zA-Z\\\\]+::retrieveAllowedOptions\\(\\) should return#"
            count: 1
            path: src/Extractors/RakeExtractor.php
